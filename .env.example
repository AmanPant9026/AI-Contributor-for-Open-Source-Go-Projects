# --- local model via Ollama (litellm provider prefix is "ollama/") ---
# Set to the EXACT tag from `ollama list`. On a 16 GB Mac use a 7B-class coder.
LLM_MODEL=ollama/qwen2.5-coder:7b
LLM_API_BASE=http://localhost:11434

# --- pinned sandbox image tag (must match `make build-sandbox`) ---
SANDBOX_IMAGE=go-issue-agent-sandbox:go1.22

# --- optional: GitHub PAT for higher API limits / private repos (host-side only) ---
# GITHUB_TOKEN=
