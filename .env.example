# --- Model (any litellm-compatible model) -------------------------------------
# For the results in the README, use Anthropic:
LLM_MODEL=anthropic/claude-sonnet-4-5
ANTHROPIC_API_KEY=

# Local, no-API-cost alternative (lower resolution); requires Ollama running:
# LLM_MODEL=ollama/qwen2.5-coder:7b
# LLM_API_BASE=http://localhost:11434

# --- Sandbox ------------------------------------------------------------------
# The pinned Go image built by `make build-sandbox`.
SANDBOX_IMAGE=go-issue-agent-sandbox:dev

# --- GitHub -------------------------------------------------------------------
# Needed to build instances from issues/PRs (eval/make_instance.py) and to open
# draft PRs (eval/open_pr.py).
# GITHUB_TOKEN=
